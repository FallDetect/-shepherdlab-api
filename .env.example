# Copy this to .env and fill in your values
# Add all of these as Environment Variables in Render dashboard

# PostgreSQL — from Render's free PostgreSQL addon
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Resend — for sending activation emails
# Get from resend.com — use the shepherdforms.com verified domain or add shepherdlab.life
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# APK download URL — where the APK is hosted
# Option 1: Upload APK to your Render static site or a CDN
# Option 2: Google Drive direct download link
APK_DOWNLOAD_URL=https://shepherdlab.life/download/fallguardplus-latest.apk

# Admin secret — pick any long random string, used to access /api/admin/orders
ADMIN_SECRET=change_this_to_a_long_random_string_abc123

# Telegram — your personal Telegram for order notifications (optional)
TELEGRAM_BOT_TOKEN=your_fallguard_bot_token_here
ADMIN_TELEGRAM_CHAT_ID=your_personal_chat_id_here

# Port — Render sets this automatically, don't change
PORT=3001

# ── STRIPE ────────────────────────────────────────────────────────────────────
# Get from stripe.com dashboard

# Secret key (starts with sk_live_ in production, sk_test_ for testing)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook signing secret — from Stripe Dashboard → Webhooks → your endpoint
# Listen for: checkout.session.completed, invoice.payment_succeeded, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Price IDs — create Products in Stripe Dashboard, then copy the Price ID
# Basic plan: SGD $15/month recurring
STRIPE_PRICE_BASIC=price_xxxxxxxxxxxxxxxxxxxxxxxx

# Pro plan: SGD $20/month recurring
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxxxxxx
